pkgname=rustlens
pkgver=0.6.2
pkgrel=1
pkgdesc="A powerful and intuitive ui tool for managing your Kubernetes (k8s) cluster."
arch=('x86_64')
url='https://github.com/denix666/rustlens'
license=('MIT')

source=('rustlens'
	'rustlens.png'
	'rustlens.desktop')

package() {
    cd ${srcdir}
    install -D -m755 rustlens ${pkgdir}/usr/bin/rustlens
    install -D -m644 rustlens.png ${pkgdir}/usr/share/pixmaps/rustlens.png
    install -D -m644 rustlens.desktop ${pkgdir}/usr/share/applications/rustlens.desktop
}
sha256sums=('f49279e922694daeaa7b671aec69f61191b24959c5a14538d8ee55af128dee27'
